<!--
File: MainWindow.xaml
What it does: Defines the compact overlay and expanded player menu UI.
Why it exists: Shows Spotify playback with a glass-style control menu and visualizer.
RELATED FILES: MainWindow.xaml.cs, Services/SpotifyPlaybackService.cs, Models/SpotifyNowPlaying.cs
-->
<Window x:Class="SpotiFloat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SpotiFloat"
        Width="342"
        Height="92"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Closing="Window_Closing"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseRightButtonUp="Window_MouseRightButtonUp">
    <Window.Resources>
        <LinearGradientBrush x:Key="MenuGlassBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#E0475054" Offset="0" />
            <GradientStop Color="#D8333B40" Offset="0.48" />
            <GradientStop Color="#EA151B20" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CyanFillBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF70D8EF" Offset="0" />
            <GradientStop Color="#FFC7F3FF" Offset="1" />
        </LinearGradientBrush>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#E8F7FF" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style x:Key="SeekSliderStyle" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="22">
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="7"
                                                        Background="{StaticResource CyanFillBrush}"
                                                        CornerRadius="4">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#FF91EAFF" Opacity="0.38" />
                                                    </Border.Effect>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="7" Background="#B010151A" CornerRadius="4" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="20" Height="20">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="#EFF8FC">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect BlurRadius="13" ShadowDepth="0" Color="#FFC9F6FF" Opacity="0.7" />
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="CompactOverlay">
            <Border Margin="34,14,8,10"
                    Padding="72,11,16,9"
                    Background="#F00E0E10"
                    BorderBrush="#242428"
                    BorderThickness="1"
                    CornerRadius="18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.35" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TitleText"
                               Grid.Row="0"
                               Foreground="#FFF7F7F7"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="SpotiFloat"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis" />

                    <TextBlock x:Name="ArtistText"
                               Grid.Row="1"
                               Margin="0,2,0,0"
                               Foreground="#FFB9B9BE"
                               FontSize="10"
                               Text="Play music in Spotify"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis" />

                    <Grid Grid.Row="3"
                          Width="210"
                          Height="4"
                          HorizontalAlignment="Center">
                        <Border Background="#FF5A5A66" CornerRadius="2" />
                        <Border Background="#FF20C7D8"
                                CornerRadius="2"
                                RenderTransformOrigin="0,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ProgressScale" ScaleX="0" />
                            </Border.RenderTransform>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border x:Name="AlbumArtBox"
                    Width="74"
                    Height="74"
                    Margin="14,7,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="#FF232328"
                    CornerRadius="14">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="11" ShadowDepth="2" Opacity="0.35" />
                </Border.Effect>
                <Grid>
                    <TextBlock x:Name="AlbumPlaceholder"
                               Foreground="#FF8E8E94"
                               FontSize="10"
                               Text="Spotify"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="MenuPanel"
                Width="720"
                Height="560"
                Opacity="0"
                Visibility="Collapsed"
                Margin="8"
                Padding="20"
                Background="{StaticResource MenuGlassBrush}"
                BorderBrush="#B4CDECF3"
                BorderThickness="1"
                CornerRadius="10"
                RenderTransformOrigin="0.08,0.08">
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="MenuScale" ScaleX="0.88" ScaleY="0.88" />
                    <TranslateTransform x:Name="MenuTranslate" X="-18" Y="-14" />
                </TransformGroup>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="34" ShadowDepth="0" Color="#FF8BEAFF" Opacity="0.28" />
            </Border.Effect>

            <Grid>
                <Grid.OpacityMask>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFFFFFFF" Offset="0" />
                        <GradientStop Color="#FFF7F7F7" Offset="0.72" />
                        <GradientStop Color="#FFE8E8E8" Offset="1" />
                    </LinearGradientBrush>
                </Grid.OpacityMask>
                <Grid.RowDefinitions>
                    <RowDefinition Height="258" />
                    <RowDefinition Height="1" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="252" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="225"
                            Height="225"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#3820272C"
                            CornerRadius="112">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="36" ShadowDepth="0" Color="#FFB4F2FF" Opacity="0.76" />
                        </Border.Effect>
                    </Border>

                    <Border x:Name="MenuAlbumArtBox"
                            Width="212"
                            Height="212"
                            Margin="6"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#FF20252A"
                            CornerRadius="106" />

                    <Border Width="38"
                            Height="38"
                            Margin="92,92,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#E80B1115"
                            CornerRadius="19" />

                    <StackPanel Grid.Column="1" Margin="12,14,0,0">
                        <TextBlock x:Name="MenuTitleText"
                                   Foreground="#EAF5F8"
                                   FontFamily="Consolas"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Text="SpotiFloat"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="MenuArtistText"
                                   Margin="0,9,0,0"
                                   Foreground="#D5E0E4"
                                   FontFamily="Consolas"
                                   FontSize="13"
                                   Text="BY Spotify" />
                        <TextBlock Margin="0,13,0,0"
                                   Foreground="#EAF7FA"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Text="* Spotify Desktop   VIA Windows Media Session" />

                        <Grid Margin="0,22,4,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Slider x:Name="MenuSeekSlider"
                                    Height="18"
                                    Minimum="0"
                                    Maximum="1"
                                    Value="0"
                                    IsMoveToPointEnabled="True"
                                    Style="{StaticResource SeekSliderStyle}"
                                    PreviewMouseLeftButtonDown="MenuSeekSlider_PreviewMouseLeftButtonDown"
                                    PreviewMouseLeftButtonUp="MenuSeekSlider_PreviewMouseLeftButtonUp" />
                            <Grid Grid.Row="1" Margin="0,8,0,0">
                                <TextBlock x:Name="CurrentTimeText"
                                           Foreground="#E6EEF2"
                                           FontFamily="Consolas"
                                           FontSize="13"
                                           Text="00:00" />
                                <TextBlock x:Name="DurationText"
                                           HorizontalAlignment="Right"
                                           Foreground="#E6EEF2"
                                           FontFamily="Consolas"
                                           FontSize="13"
                                           Text="00:00" />
                            </Grid>
                        </Grid>

                        <StackPanel Margin="0,25,0,0"
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                            <Button Width="58"
                                    Height="48"
                                    Click="PreviousButton_Click"
                                    Style="{StaticResource IconButtonStyle}">
                                <Viewbox Width="28" Height="28">
                                    <Canvas Width="32" Height="32">
                                        <Path Fill="#E8F7FF" Data="M8,6 L11,6 L11,26 L8,26 Z M24,6 L13,16 L24,26 Z" />
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Button x:Name="PlayPauseButton"
                                    Width="74"
                                    Height="56"
                                    Margin="27,0"
                                    Click="PlayPauseButton_Click"
                                    Style="{StaticResource IconButtonStyle}">
                                <Grid>
                                    <Viewbox x:Name="PauseIcon" Width="36" Height="36">
                                        <Canvas Width="32" Height="32">
                                            <Path Fill="#9FE8FF" Data="M8,5 L14,5 L14,27 L8,27 Z M18,5 L24,5 L24,27 L18,27 Z" />
                                        </Canvas>
                                    </Viewbox>
                                    <Viewbox x:Name="PlayIcon" Width="36" Height="36" Visibility="Collapsed">
                                        <Canvas Width="32" Height="32">
                                            <Path Fill="#9FE8FF" Data="M9,5 L26,16 L9,27 Z" />
                                        </Canvas>
                                    </Viewbox>
                                </Grid>
                            </Button>
                            <Button Width="58"
                                    Height="48"
                                    Click="NextButton_Click"
                                    Style="{StaticResource IconButtonStyle}">
                                <Viewbox Width="28" Height="28">
                                    <Canvas Width="32" Height="32">
                                        <Path Fill="#E8F7FF" Data="M21,6 L24,6 L24,26 L21,26 Z M8,6 L19,16 L8,26 Z" />
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Background="#4FD3F6FF" />

                <Grid Grid.Row="2" Margin="0,19,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="96" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <TextBlock Foreground="#BDEFFF"
                                   FontFamily="Consolas"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Visualizer" />
                        <Border HorizontalAlignment="Right"
                                Padding="16,8"
                                Background="#CC141920"
                                CornerRadius="8">
                            <TextBlock Foreground="#E6F4F8"
                                       FontFamily="Consolas"
                                       Text="Live" />
                        </Border>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,14,0,0"
                            Padding="16,12"
                            Background="#8A151C22"
                            BorderBrush="#306FDDF3"
                            BorderThickness="1"
                            CornerRadius="10">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#FF7BE7FF" Opacity="0.18" />
                        </Border.Effect>
                    </Border>

                    <Grid x:Name="VisualizerGrid"
                          Grid.Row="1"
                          Margin="16,23,16,9">
                        <UniformGrid Columns="20" VerticalAlignment="Bottom">
                            <Border Height="34" Margin="5,0" Background="#A5BDEFFF" CornerRadius="5" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz01" ScaleY="0.55" /></Border.RenderTransform></Border>
                            <Border Height="58" Margin="5,0" Background="#BDBDEFFF" CornerRadius="5" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz02" ScaleY="0.75" /></Border.RenderTransform></Border>
                            <Border Height="78" Margin="5,0" Background="#D0BDEFFF" CornerRadius="5" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz03" ScaleY="0.45" /></Border.RenderTransform></Border>
                            <Border Height="50" Margin="5,0" Background="#BDBDEFFF" CornerRadius="5" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz04" ScaleY="0.68" /></Border.RenderTransform></Border>
                            <Border Height="82" Margin="5,0" Background="#E29FE8FF" CornerRadius="5" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz05" ScaleY="0.42" /></Border.RenderTransform></Border>
                            <Border Height="44" Margin="5,0" Background="#BDBDEFFF" CornerRadius="5" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz06" ScaleY="0.7" /></Border.RenderTransform></Border>
                            <Border Height="70" Margin="5,0" Background="#D8BDEFFF" CornerRadius="5" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz07" ScaleY="0.5" /></Border.RenderTransform></Border>
                            <Border Height="54" Margin="5,0" Background="#BDBDEFFF" CornerRadius="5" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz08" ScaleY="0.82" /></Border.RenderTransform></Border>
                            <Border Height="86" Margin="5,0" Background="#E29FE8FF" CornerRadius="5" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz09" ScaleY="0.58" /></Border.RenderTransform></Border>
                            <Border Height="46" Margin="5,0" Background="#BDBDEFFF" CornerRadius="5" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz10" ScaleY="0.64" /></Border.RenderTransform></Border>
                            <Border Height="62" Margin="5,0" Background="#C8BDEFFF" CornerRadius="5" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz11" ScaleY="0.48" /></Border.RenderTransform></Border>
                            <Border Height="80" Margin="5,0" Background="#D89FE8FF" CornerRadius="5" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz12" ScaleY="0.7" /></Border.RenderTransform></Border>
                            <Border Height="42" Margin="5,0" Background="#BDBDEFFF" CornerRadius="5" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz13" ScaleY="0.5" /></Border.RenderTransform></Border>
                            <Border Height="74" Margin="5,0" Background="#D0BDEFFF" CornerRadius="5" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz14" ScaleY="0.84" /></Border.RenderTransform></Border>
                            <Border Height="52" Margin="5,0" Background="#BDBDEFFF" CornerRadius="5" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz15" ScaleY="0.44" /></Border.RenderTransform></Border>
                            <Border Height="84" Margin="5,0" Background="#E29FE8FF" CornerRadius="5" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz16" ScaleY="0.62" /></Border.RenderTransform></Border>
                            <Border Height="48" Margin="5,0" Background="#BDBDEFFF" CornerRadius="5" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz17" ScaleY="0.76" /></Border.RenderTransform></Border>
                            <Border Height="68" Margin="5,0" Background="#D0BDEFFF" CornerRadius="5" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz18" ScaleY="0.54" /></Border.RenderTransform></Border>
                            <Border Height="38" Margin="5,0" Background="#A5BDEFFF" CornerRadius="5" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz19" ScaleY="0.68" /></Border.RenderTransform></Border>
                            <Border Height="76" Margin="5,0" Background="#D89FE8FF" CornerRadius="5" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz20" ScaleY="0.46" /></Border.RenderTransform></Border>
                        </UniformGrid>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,18,0,0">
                        <TextBlock Foreground="#AEEAF7FF"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Text="Right click or Ctrl+Alt+M to close menu"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Bottom" />
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
