<!--
File: MainWindow.xaml
What it does: Defines the compact overlay and expanded player menu UI.
Why it exists: Shows Spotify playback in a small animated glass-style player.
RELATED FILES: MainWindow.xaml.cs, Services/SpotifyPlaybackService.cs, Models/SpotifyNowPlaying.cs
-->
<Window x:Class="SpotiFloat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SpotiFloat"
        Width="250"
        Height="42"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Closing="Window_Closing"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseRightButtonUp="Window_MouseRightButtonUp">
    <Window.Resources>
        <LinearGradientBrush x:Key="MenuGlassBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F0181A21" Offset="0" />
            <GradientStop Color="#F520222B" Offset="0.52" />
            <GradientStop Color="#FA0D0F15" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PopupBorderBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFDA8CFF" Offset="0" />
            <GradientStop Color="#FF72D9FF" Offset="0.45" />
            <GradientStop Color="#FFFF799C" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FFB28CFF" Offset="0" />
            <GradientStop Color="#FF77DFFF" Offset="0.52" />
            <GradientStop Color="#FFFF83A7" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="VisualizerBrush" StartPoint="0,1" EndPoint="0,0">
            <GradientStop Color="#FF8F7CFF" Offset="0" />
            <GradientStop Color="#FF74DFFF" Offset="0.55" />
            <GradientStop Color="#FFFF91B1" Offset="1" />
        </LinearGradientBrush>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#F2F4FF" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonSurface"
                                Background="{TemplateBinding Background}"
                                CornerRadius="22">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#24FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#3FFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SeekSliderStyle" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="20">
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="5"
                                                        Background="{StaticResource AccentBrush}"
                                                        CornerRadius="3">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#FF8DE7FF" Opacity="0.35" />
                                                    </Border.Effect>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="5" Background="#5511141C" CornerRadius="3" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="15" Height="15">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="#FFF8FAFF" Stroke="#80FFFFFF" StrokeThickness="1">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#FF9CEAFF" Opacity="0.7" />
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="TaskbarOverlay" Opacity="0" Cursor="Hand">
            <Border Background="#D01E1E2E"
                    BorderBrush="#24CDD6F4"
                    BorderThickness="1"
                    CornerRadius="11">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="34"
                            Height="34"
                            Margin="4,3"
                            Background="{StaticResource PopupBorderBrush}"
                            CornerRadius="9">
                        <Border x:Name="TaskbarAlbumArtBox"
                                Margin="1"
                                Background="#FF23252D"
                                CornerRadius="8">
                            <Grid>
                                <TextBlock x:Name="TaskbarAlbumPlaceholder"
                                           Foreground="#FFA6ADC8"
                                           FontSize="7"
                                           Text="S"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                <Border Background="#24CBA6F7" CornerRadius="8" />
                            </Grid>
                        </Border>
                    </Border>

                    <Grid Grid.Column="1" Margin="10,0,12,0">
                        <StackPanel Margin="0,0,0,3" VerticalAlignment="Center">
                            <TextBlock x:Name="TaskbarTitleText"
                                       Foreground="#FFCDD6F4"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       LineHeight="13"
                                       LineStackingStrategy="BlockLineHeight"
                                       Text="SpotiFloat"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="TaskbarArtistText"
                                       Foreground="#FFA6ADC8"
                                       FontFamily="Consolas"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       LineHeight="10"
                                       LineStackingStrategy="BlockLineHeight"
                                       Text="Spotify"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Grid Height="2"
                              Margin="0,0,0,4"
                              VerticalAlignment="Bottom">
                            <Border Background="#5045465A" CornerRadius="1" />
                            <Border Background="{StaticResource AccentBrush}"
                                    CornerRadius="1"
                                    RenderTransformOrigin="0,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="TaskbarProgressScale" ScaleX="0" />
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="CompactOverlay" Visibility="Collapsed">
            <Border Margin="34,14,8,10"
                    Padding="72,11,16,9"
                    Background="#F20D0F14"
                    BorderBrush="#505D6270"
                    BorderThickness="1"
                    CornerRadius="18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="2" Color="#CC000000" Opacity="0.5" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="TitleText"
                               Foreground="#FFF7F7FB"
                               FontFamily="Segoe UI Variable Display"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="SpotiFloat"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="ArtistText"
                               Grid.Row="1"
                               Margin="0,2,0,0"
                               Foreground="#FFAAAEBB"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="10"
                               Text="Play music in Spotify"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                    <Grid Grid.Row="3" Width="210" Height="3" HorizontalAlignment="Center">
                        <Border Background="#FF353944" CornerRadius="2" />
                        <Border Background="{StaticResource AccentBrush}"
                                CornerRadius="2"
                                RenderTransformOrigin="0,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ProgressScale" ScaleX="0" />
                            </Border.RenderTransform>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Width="78"
                    Height="78"
                    Margin="12,5,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="{StaticResource PopupBorderBrush}"
                    CornerRadius="16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2" Color="#FF88DFFF" Opacity="0.3" />
                </Border.Effect>
                <Border x:Name="AlbumArtBox"
                        Margin="2"
                        Background="#FF23252D"
                        CornerRadius="14">
                    <Grid>
                        <TextBlock x:Name="AlbumPlaceholder"
                                   Foreground="#FF8E929E"
                                   FontSize="10"
                                   Text="Spotify"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Border>
        </Grid>

        <Popup x:Name="MenuPopup"
               AllowsTransparency="True"
               Placement="Top"
               PlacementTarget="{Binding ElementName=TaskbarOverlay}"
               StaysOpen="True"
               VerticalOffset="-8">
        <Border x:Name="MenuPanel"
                Width="500"
                Height="330"
                Margin="8"
                Padding="18"
                Opacity="0"
                Visibility="Collapsed"
                Background="{StaticResource MenuGlassBrush}"
                BorderThickness="2"
                CornerRadius="14"
                ClipToBounds="True"
                RenderTransformOrigin="0.08,0.92">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <LinearGradientBrush.RelativeTransform>
                        <RotateTransform x:Name="PopupBorderRotate" CenterX="0.5" CenterY="0.5" />
                    </LinearGradientBrush.RelativeTransform>
                    <GradientStop Color="#FFDA8CFF" Offset="0" />
                    <GradientStop Color="#FF72D9FF" Offset="0.45" />
                    <GradientStop Color="#FFFF799C" Offset="0.75" />
                    <GradientStop Color="#FFDA8CFF" Offset="1" />
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="MenuScale" ScaleX="0.92" ScaleY="0.92" />
                    <TranslateTransform x:Name="MenuTranslate" X="-12" Y="12" />
                </TransformGroup>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="38" ShadowDepth="0" Color="#FF7CDFFF" Opacity="0.3" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="228" />
                    <RowDefinition Height="1" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="164" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="MenuBackdrop"
                        Grid.RowSpan="3"
                        Grid.ColumnSpan="2"
                        Margin="-12"
                        Opacity="0.13"
                        CornerRadius="10">
                    <Border.Effect>
                        <BlurEffect Radius="24" />
                    </Border.Effect>
                </Border>
                <Border Grid.RowSpan="3"
                        Grid.ColumnSpan="2"
                        Margin="-18"
                        Background="#78101219"
                        CornerRadius="12" />

                <Grid Width="148"
                      Height="148"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center"
                      RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="MenuAlbumScale" ScaleX="0.78" ScaleY="0.78" />
                            <TranslateTransform x:Name="MenuAlbumTranslate" X="-30" Y="8" />
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <Ellipse Width="146"
                             Height="146"
                             Stroke="{StaticResource PopupBorderBrush}"
                             StrokeThickness="4"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="RingRotate" />
                        </Ellipse.RenderTransform>
                        <Ellipse.Effect>
                            <DropShadowEffect BlurRadius="22" ShadowDepth="0" Color="#FF8CDFFF" Opacity="0.5" />
                        </Ellipse.Effect>
                    </Ellipse>
                    <Grid Width="134"
                          Height="134"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <RotateTransform x:Name="AlbumRotate" />
                        </Grid.RenderTransform>
                        <Border x:Name="MenuAlbumArtBox"
                                Background="#FF22252D"
                                CornerRadius="67" />
                        <Border Background="#22000000" CornerRadius="67" />
                        <Ellipse Width="26" Height="26" Fill="#E80A0C11" Stroke="#503F4652" StrokeThickness="1" />
                        <Ellipse Width="7" Height="7" Fill="#FFBFC5D2" />
                    </Grid>
                </Grid>

                <Grid Grid.Row="0"
                      Grid.Column="1"
                      Margin="10,2,0,2"
                      RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="MenuContentTranslate" X="28" />
                    </Grid.RenderTransform>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            HorizontalAlignment="Left"
                            Padding="8,3"
                            Background="#261FB9D4"
                            BorderBrush="#4077DFFF"
                            BorderThickness="1"
                            CornerRadius="8">
                        <TextBlock Foreground="#FF9CEAFF"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Text="SPOTIFY DESKTOP" />
                    </Border>
                    <TextBlock x:Name="MenuTitleText"
                               Grid.Row="1"
                               Margin="0,9,0,0"
                               Foreground="#FFF7F7FC"
                               FontFamily="Segoe UI Variable Display"
                               FontSize="19"
                               FontWeight="SemiBold"
                               Text="SpotiFloat"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="MenuArtistText"
                               Grid.Row="2"
                               Margin="0,3,0,0"
                               Foreground="#FFADB1BE"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="11"
                               Text="Spotify"
                               TextTrimming="CharacterEllipsis" />

                    <Grid Grid.Row="3" Margin="0,16,0,0">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="MenuProgressTranslate" Y="12" />
                        </Grid.RenderTransform>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Slider x:Name="MenuSeekSlider"
                                Height="20"
                                Minimum="0"
                                Maximum="1"
                                Value="0"
                                IsMoveToPointEnabled="True"
                                Style="{StaticResource SeekSliderStyle}"
                                PreviewMouseLeftButtonDown="MenuSeekSlider_PreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="MenuSeekSlider_PreviewMouseLeftButtonUp" />
                        <Grid Grid.Row="1" Margin="1,3,1,0">
                            <TextBlock x:Name="CurrentTimeText"
                                       Foreground="#FF9EA4B2"
                                       FontFamily="Consolas"
                                       FontSize="10"
                                       Text="00:00" />
                            <TextBlock x:Name="DurationText"
                                       HorizontalAlignment="Right"
                                       Foreground="#FF9EA4B2"
                                       FontFamily="Consolas"
                                       FontSize="10"
                                       Text="00:00" />
                        </Grid>
                    </Grid>

                    <StackPanel x:Name="MenuControls"
                                Grid.Row="4"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <StackPanel.RenderTransform>
                            <TranslateTransform x:Name="MenuControlsTranslate" Y="15" />
                        </StackPanel.RenderTransform>
                        <Button Width="44"
                                Height="44"
                                Click="PreviousButton_Click"
                                Style="{StaticResource IconButtonStyle}">
                            <Viewbox Width="21" Height="21">
                                <Canvas Width="32" Height="32">
                                    <Path Fill="#DDE5F2" Data="M8,6 L11,6 L11,26 L8,26 Z M24,6 L13,16 L24,26 Z" />
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button x:Name="PlayPauseButton"
                                Width="52"
                                Height="52"
                                Margin="14,0"
                                Click="PlayPauseButton_Click"
                                Background="#24FFFFFF"
                                Style="{StaticResource IconButtonStyle}">
                            <Grid>
                                <Ellipse Fill="{StaticResource AccentBrush}">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#FF8DE5FF" Opacity="0.38" />
                                    </Ellipse.Effect>
                                </Ellipse>
                                <Viewbox x:Name="PauseIcon" Width="22" Height="22">
                                    <Canvas Width="32" Height="32">
                                        <Path Fill="#FF11141B" Data="M8,6 L14,6 L14,26 L8,26 Z M18,6 L24,6 L24,26 L18,26 Z" />
                                    </Canvas>
                                </Viewbox>
                                <Viewbox x:Name="PlayIcon" Width="22" Height="22" Visibility="Collapsed">
                                    <Canvas Width="32" Height="32">
                                        <Path Fill="#FF11141B" Data="M10,6 L25,16 L10,26 Z" />
                                    </Canvas>
                                </Viewbox>
                            </Grid>
                        </Button>
                        <Button Width="44"
                                Height="44"
                                Click="NextButton_Click"
                                Style="{StaticResource IconButtonStyle}">
                            <Viewbox Width="21" Height="21">
                                <Canvas Width="32" Height="32">
                                    <Path Fill="#DDE5F2" Data="M21,6 L24,6 L24,26 L21,26 Z M8,6 L19,16 L8,26 Z" />
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Background="#406C7486" />

                <Grid x:Name="VisualizerGrid"
                      Grid.Row="2"
                      Grid.ColumnSpan="2"
                      Margin="0,7,0,0"
                      Opacity="0">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="VisualizerTranslate" Y="8" />
                    </Grid.RenderTransform>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="112" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Foreground="#FFE4E7F1"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Text="AUDIO SPECTRUM" />
                        <TextBlock Margin="0,2,0,0"
                                   Foreground="#FF777E8F"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="8"
                                   Text="LOW  /  HIGH" />
                    </StackPanel>

                    <UniformGrid Grid.Column="1"
                                 Columns="10"
                                 Height="40"
                                 VerticalAlignment="Center">
                        <Border Height="38" Margin="8,0" Background="{StaticResource VisualizerBrush}" CornerRadius="4" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz01" ScaleY="0.12" /></Border.RenderTransform></Border>
                        <Border Height="38" Margin="8,0" Background="{StaticResource VisualizerBrush}" CornerRadius="4" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz02" ScaleY="0.12" /></Border.RenderTransform></Border>
                        <Border Height="38" Margin="8,0" Background="{StaticResource VisualizerBrush}" CornerRadius="4" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz03" ScaleY="0.12" /></Border.RenderTransform></Border>
                        <Border Height="38" Margin="8,0" Background="{StaticResource VisualizerBrush}" CornerRadius="4" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz04" ScaleY="0.12" /></Border.RenderTransform></Border>
                        <Border Height="38" Margin="8,0" Background="{StaticResource VisualizerBrush}" CornerRadius="4" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz05" ScaleY="0.12" /></Border.RenderTransform></Border>
                        <Border Height="38" Margin="8,0" Background="{StaticResource VisualizerBrush}" CornerRadius="4" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz06" ScaleY="0.12" /></Border.RenderTransform></Border>
                        <Border Height="38" Margin="8,0" Background="{StaticResource VisualizerBrush}" CornerRadius="4" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz07" ScaleY="0.12" /></Border.RenderTransform></Border>
                        <Border Height="38" Margin="8,0" Background="{StaticResource VisualizerBrush}" CornerRadius="4" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz08" ScaleY="0.12" /></Border.RenderTransform></Border>
                        <Border Height="38" Margin="8,0" Background="{StaticResource VisualizerBrush}" CornerRadius="4" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz09" ScaleY="0.12" /></Border.RenderTransform></Border>
                        <Border Height="38" Margin="8,0" Background="{StaticResource VisualizerBrush}" CornerRadius="4" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1"><Border.RenderTransform><ScaleTransform x:Name="Viz10" ScaleY="0.12" /></Border.RenderTransform></Border>
                    </UniformGrid>
                </Grid>
            </Grid>
        </Border>
        </Popup>
    </Grid>
</Window>
