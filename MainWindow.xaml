<!--
File: MainWindow.xaml
What it does: Defines the always-on-top Spotify overlay UI.
Why it exists: Shows the current Spotify track in a compact floating window.
RELATED FILES: MainWindow.xaml.cs, Services/SpotifyPlaybackService.cs, Models/SpotifyNowPlaying.cs
-->
<Window x:Class="SpotiFloat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SpotiFloat"
        Width="420"
        Height="118"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Closing="Window_Closing"
        Loaded="Window_Loaded"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Grid>
        <Border Margin="40,18,8,12"
                Padding="94,18,20,14"
                Background="#F00E0E10"
                BorderBrush="#242428"
                BorderThickness="1"
                CornerRadius="22">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  ShadowDepth="4"
                                  Opacity="0.35" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="TitleText"
                           Grid.Row="0"
                           Foreground="#FFF7F7F7"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Text="SpotiFloat"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <TextBlock x:Name="ArtistText"
                           Grid.Row="1"
                           Margin="0,2,0,0"
                           Foreground="#FFB9B9BE"
                           FontSize="12"
                           Text="Connect Spotify to start"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <Grid Grid.Row="3"
                      Height="4"
                      Margin="0,2,0,0">
                    <Border Background="#FF25252A"
                            CornerRadius="2" />
                    <Border x:Name="ProgressFill"
                            Width="0"
                            HorizontalAlignment="Left"
                            Background="#FF20C7D8"
                            CornerRadius="2" />
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="AlbumArtBox"
                Width="96"
                Height="96"
                Margin="16,8,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="#FF232328"
                CornerRadius="18">
            <Border.Effect>
                <DropShadowEffect BlurRadius="14"
                                  ShadowDepth="3"
                                  Opacity="0.35" />
            </Border.Effect>
            <Grid>
                <TextBlock x:Name="AlbumPlaceholder"
                           Foreground="#FF8E8E94"
                           FontSize="11"
                           Text="Spotify"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

    </Grid>
</Window>
