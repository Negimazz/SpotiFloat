<!--
File: SettingsWindow.xaml
What it does: Defines the Spotify settings dialog.
Why it exists: Lets users set the Spotify Client ID from the tray menu.
RELATED FILES: SettingsWindow.xaml.cs, Services/AppSettingsService.cs, MainWindow.xaml.cs
-->
<Window x:Class="SpotiFloat.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SpotiFloat Settings"
        Width="420"
        Height="178"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Spotify Client ID"
                   FontSize="14"
                   FontWeight="SemiBold" />

        <TextBox x:Name="ClientIdTextBox"
                 Grid.Row="1"
                 Height="30"
                 Margin="0,8,0,0"
                 VerticalContentAlignment="Center" />

        <TextBlock Grid.Row="2"
                   Margin="0,8,0,0"
                   Foreground="#FF666666"
                   Text="Paste the Client ID from Spotify Developer Dashboard."
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="3"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="84"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"
                    Content="Cancel" />
            <Button Width="84"
                    Height="30"
                    Click="SaveButton_Click"
                    Content="Save" />
        </StackPanel>
    </Grid>
</Window>
